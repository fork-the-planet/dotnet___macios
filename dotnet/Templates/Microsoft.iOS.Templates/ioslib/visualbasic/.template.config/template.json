{
  "$schema": "http://json.schemastore.org/template",
  "author": "Microsoft",
  "classifications": [ "iOS", "Mobile" ],
  "groupIdentity": "Microsoft.iOS.iOSLib",
  "identity": "Microsoft.iOS.iOSLib.VisualBasic",
  "name": "iOS Class Library",
  "description": "A project for creating a .NET iOS class library",
  "shortName": "ioslib",
  "tags": {
    "language": "VB",
    "type": "project"
  },
  "sourceName": "iOSLib1",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "iOSLib1.vbproj" }
  ],
  "defaultName": "iOSLib1",
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0-ios",
          "description": "Target net10.0-ios"
        }
      ],
      "replaces": "net10.0-ios",
      "defaultValue": "net10.0-ios"
    }
  }
}
